<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. ADB Wireless Pairing"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"/>
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buka Developer Options > Wireless Debugging > Pair device with pairing code."
            android:textSize="12sp"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <EditText
                android:id="@+id/etPairingPort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Pairing Port"
                android:inputType="number" />

            <EditText
                android:id="@+id/etPairingCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Pairing Code (6 digit)"
                android:inputType="number" />
        </LinearLayout>

        <EditText
            android:id="@+id/etConnectPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Connection Port (di halaman depan Wireless Debug)"
            android:inputType="number"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnConnectAdb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hubungkan &amp; Beri Izin"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvAdbStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Belum Terhubung"
            android:textStyle="italic"
            android:textColor="#FF0000"
            android:layout_marginTop="8dp"
            android:paddingBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Lokasi Palsu (Mock Location)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"/>

        <EditText
            android:id="@+id/etLatitude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Latitude (Contoh: -6.214452)"
            android:inputType="numberSigned|numberDecimal" />

        <EditText
            android:id="@+id/etLongitude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Longitude (Contoh: 106.817617)"
            android:inputType="numberSigned|numberDecimal"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnStartMock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start"
                android:backgroundTint="#4CAF50"/>

            <Button
                android:id="@+id/btnStopMock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop"
                android:backgroundTint="#F44336"
                android:layout_marginLeft="8dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Log Activity..."
            android:textSize="12sp"
            android:maxLines="10"
            android:scrollbars="vertical" />

    </LinearLayout>
</ScrollView>
